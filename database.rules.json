{
  "rules": {
    "sessions": {
      "$sessionCode": {
        ".read": true,
        "hostUid": {
          ".write": "!data.exists()"
        },
        "status": {
          ".write": "auth != null && auth.uid === newData.parent().child('hostUid').val()"
        },
        "createdAt": {
          ".write": "!data.exists()"
        },
        "currentQuestion": {
          ".write": "auth != null && auth.uid === newData.parent().child('hostUid').val()"
        },
        "players": {
          "$uid": {
            ".write": "auth != null && auth.uid === $uid",
            "votes": {
              "$questionId": {
                ".write": "auth != null && auth.uid === $uid && !data.exists()"
              }
            }
          }
        }
      }
    }
  }
}
